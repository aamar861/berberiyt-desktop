{
  "name": "berberiyt-desktop",
  "productName": "BerberiYt",
  "version": "1.0.0",
  "description": "BerberiYt — rezervime online per berbershopet",
  "author": "BerberiYt <amarberisha72@gmail.com>",
  "license": "UNLICENSED",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:all": "electron-builder --win --mac"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.berberiyt.app",
    "productName": "BerberiYt",
    "copyright": "Copyright © 2026 BerberiYt",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "offline.html",
      "build/icon.png"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "artifactName": "BerberiYt-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BerberiYt"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["universal"]
        }
      ],
      "category": "public.app-category.business",
      "artifactName": "BerberiYt-Mac.${ext}"
    },
    "dmg": {
      "title": "BerberiYt"
    }
  }
}
